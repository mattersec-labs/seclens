# SecLens — required API keys per provider
# Copy to .env and fill in the keys you need.

# Anthropic (provider: anthropic)
ANTHROPIC_API_KEY=

# OpenAI (provider: openai)
OPENAI_API_KEY=

# Google Gemini (provider: google)
GOOGLE_API_KEY=

# Ollama (provider: ollama) — no key needed, runs locally
# OLLAMA_HOST=http://localhost:11434

# LiteLLM (provider: litellm) — set the key for whichever upstream provider you route through
# LITELLM_API_KEY=
